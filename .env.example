PORT=3000

# Required staff route keys (server fails fast if missing)
FRONT_DESK_KEY=replace-me
RACE_CONTROL_KEY=replace-me
LAP_LINE_TRACKER_KEY=replace-me

# Demo/testing convenience only. When true, staff routes skip the key gate
# and the required key checks above are not enforced at startup.
STAFF_AUTH_DISABLED=false

# Optional override (seconds). If empty:
# - npm run dev => 60
# - npm start => 600
RACE_DURATION_SECONDS=

# Optional failed-auth delay override in milliseconds (default 500)
AUTH_FAILURE_DELAY_MS=500
